HOST=127.0.0.1
PORT=3000

# Optional HoYoLAB integration.
# RISK: Keep these values private. Do not commit a real .env file to GitHub.
# Never paste a HoYoVerse password here. Use cookies only from your own browser session.
ZZZ_UID=
ZZZ_REGION=prod_gf_jp
HOYOLAB_COOKIE_VERSION=v2
HOYOLAB_LTUID=
HOYOLAB_LTOKEN=

# Optional/advanced. Needed for owned agent details and equipped drive discs.
# These values are more fragile and may change when HoYoLAB changes its web app.
HOYOLAB_E_NAP_TOKEN=
HOYOLAB_DEVICE_FP=
HOYOLAB_DEVICE_ID=
HOYOLAB_LANG=ja-jp
HOYOLAB_COOKIE_EXTRA=
HOYOLAB_CACHE_TTL_SECONDS=300
